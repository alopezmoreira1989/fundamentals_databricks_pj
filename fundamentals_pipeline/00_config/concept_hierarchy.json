      "children": [
        { "concept": "R&D Expense",        "display_name": "R&D" },
        { "concept": "SG&A Expense",       "display_name": "SG&A" },
        { "concept": "Operating Expenses" },
        { "concept": "Operating Income" }
      ]
    },
    {
      "group": "Non-Operating",
      "children": [
        { "concept": "Interest Expense" },
        { "concept": "Income Before Tax" }
      ]
    },
    {
