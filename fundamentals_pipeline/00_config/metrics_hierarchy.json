{
  "_comment": "Jerarquía de derived metrics (financials_metrics). Dos niveles: category → subcategory → metric. Cada metric es una fila en main.config.metrics_hierarchy. El campo 'requires_market_data' indica si la métrica depende de la tabla market_data (se computa solo si 12__fetch_market_data se ha ejecutado). El orden en este JSON determina el sort_order final (10, 20, 30, ...).",

  "Profitability": {
    "Margins": [
      { "metric": "Gross Margin %",     "unit": "percent", "requires_market_data": false },
      { "metric": "Operating Margin %", "unit": "percent", "requires_market_data": false },
      { "metric": "Net Margin %",       "unit": "percent", "requires_market_data": false }
    ],
    "Returns": [
      { "metric": "ROA %",   "unit": "percent", "requires_market_data": false },
      { "metric": "ROE %",   "unit": "percent", "requires_market_data": false },
      { "metric": "ROIC %",  "unit": "percent", "requires_market_data": false },
      { "metric": "ROCE %",  "unit": "percent", "requires_market_data": false },
      { "metric": "CROIC %", "unit": "percent", "requires_market_data": false }
    ]
  },

  "Cash Flow": {
    "Absolute": [
      { "metric": "Operating Cash Flow", "unit": "usd", "requires_market_data": false },
      { "metric": "CapEx",               "unit": "usd", "requires_market_data": false },
      { "metric": "Free Cash Flow",      "unit": "usd", "requires_market_data": false }
    ],
    "Margins": [
      { "metric": "Op Cash Flow Margin %", "unit": "percent", "requires_market_data": false },
      { "metric": "FCF Margin %",          "unit": "percent", "requires_market_data": false }
    ],
    "Yields": [
      { "metric": "Op Cash Flow Yield %", "unit": "percent", "requires_market_data": true },
      { "metric": "FCF Yield %",          "unit": "percent", "requires_market_data": true }
    ]
  },

  "Growth": {
    "YoY": [
      { "metric": "Revenue YoY %",             "unit": "percent", "requires_market_data": false },
      { "metric": "Net Income YoY %",          "unit": "percent", "requires_market_data": false },
      { "metric": "Operating Cash Flow YoY %", "unit": "percent", "requires_market_data": false },
      { "metric": "Free Cash Flow YoY %",      "unit": "percent", "requires_market_data": false }
    ]
  },

  "Financial Health": {
    "Leverage": [
      { "metric": "Debt / Equity", "unit": "ratio", "requires_market_data": false },
      { "metric": "Debt / Assets", "unit": "ratio", "requires_market_data": false }
    ],
    "Liquidity": [
      { "metric": "Current Ratio", "unit": "ratio", "requires_market_data": false }
    ]
  },

  "Valuation": {
    "Price Multiples": [
      { "metric": "P/E",   "unit": "ratio", "requires_market_data": true },
      { "metric": "P/S",   "unit": "ratio", "requires_market_data": true },
      { "metric": "P/FCF", "unit": "ratio", "requires_market_data": true },
      { "metric": "P/B",   "unit": "ratio", "requires_market_data": true }
    ],
    "Enterprise Value": [
      { "metric": "EV",        "unit": "usd",   "requires_market_data": true },
      { "metric": "EV/EBITDA", "unit": "ratio", "requires_market_data": true }
    ],
    "Yields": [
      { "metric": "Earnings Yield %", "unit": "percent", "requires_market_data": true },
      { "metric": "Sales Yield %",    "unit": "percent", "requires_market_data": true },
      { "metric": "Book Yield %",     "unit": "percent", "requires_market_data": true },
      { "metric": "EBITDA Yield %",   "unit": "percent", "requires_market_data": true }
    ]
  },

  "Intrinsic Value": {
    "Graham (FY)": [
      { "metric": "Graham Number (FY)",          "unit": "usd",     "requires_market_data": false },
      { "metric": "MoS % (Graham Number, FY)",   "unit": "percent", "requires_market_data": true  },
      { "metric": "Graham Revised Value (FY)",   "unit": "usd",     "requires_market_data": false },
      { "metric": "MoS % (Graham Revised, FY)",  "unit": "percent", "requires_market_data": true  }
    ],
    "DCF (FY)": [
      { "metric": "DCF Value per Share (FY)",    "unit": "usd",     "requires_market_data": false },
      { "metric": "MoS % (DCF, FY)",             "unit": "percent", "requires_market_data": true  }
    ],
    "Buffett (FY)": [
      { "metric": "Owner Earnings (FY)",            "unit": "usd",     "requires_market_data": false },
      { "metric": "Owner Earnings Value/Share (FY)","unit": "usd",     "requires_market_data": false },
      { "metric": "MoS % (Owner Earnings, FY)",     "unit": "percent", "requires_market_data": true  }
    ],
    "Graham (TTM)": [
      { "metric": "Graham Number (TTM)",         "unit": "usd",     "requires_market_data": false },
      { "metric": "MoS % (Graham Number, TTM)",  "unit": "percent", "requires_market_data": true  },
      { "metric": "Graham Revised Value (TTM)",  "unit": "usd",     "requires_market_data": false },
      { "metric": "MoS % (Graham Revised, TTM)", "unit": "percent", "requires_market_data": true  }
    ],
    "DCF (TTM)": [
      { "metric": "DCF Value per Share (TTM)",   "unit": "usd",     "requires_market_data": false },
      { "metric": "MoS % (DCF, TTM)",            "unit": "percent", "requires_market_data": true  }
    ],
    "Buffett (TTM)": [
      { "metric": "Owner Earnings (TTM)",            "unit": "usd",     "requires_market_data": false },
      { "metric": "Owner Earnings Value/Share (TTM)","unit": "usd",     "requires_market_data": false },
      { "metric": "MoS % (Owner Earnings, TTM)",     "unit": "percent", "requires_market_data": true  }
    ]
  }
}
