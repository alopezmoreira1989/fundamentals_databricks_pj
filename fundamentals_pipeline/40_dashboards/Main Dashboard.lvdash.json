    {
      "name": "96deb0c6",
      "displayName": "devired_metrics",
      "queryLines": [
        "WITH ranked AS (\r\n",
        "    SELECT\r\n",
        "        m.ticker,\r\n",
        "        m.fiscal_year,\r\n",
        "        m.value,\r\n",
        "        h.category,\r\n",
        "        h.subcategory,\r\n",
        "        h.metric,\r\n",
        "        h.sort_order,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY h.category)                 AS category_sort,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY h.category, h.subcategory)  AS subcategory_sort\r\n",
        "    FROM main.financials.financials_metrics m\r\n",
        "    JOIN main.config.metrics_hierarchy h\r\n",
        "        ON h.metric = m.metric\r\n",
        ")\r\n",
        "SELECT\r\n",
        "    ticker,\r\n",
        "    fiscal_year,\r\n",
        "    LPAD(CAST(category_sort    AS STRING), 3, '0') || ' ' || category     AS category,\r\n",
        "    LPAD(CAST(subcategory_sort AS STRING), 3, '0') || ' ' || subcategory  AS subcategory,\r\n",
        "    LPAD(CAST(sort_order       AS STRING), 3, '0') || ' ' || metric       AS metric,\r\n",
        "    ROUND(ANY_VALUE(value), 2) AS value\r\n",
        "FROM ranked\r\n",
        "GROUP BY\r\n",
        "    ticker, fiscal_year, category_sort, category, subcategory_sort, subcategory, sort_order, metric\r\n",
        "ORDER BY\r\n",
        "    ticker, fiscal_year, sort_order"
      ]
    },
    {
      "name": "b8d55986",
      "displayName": "ds_quarterly_revenue_yoy",
      "queryLines": [
        "WITH quarterly AS (\r\n",
        "    SELECT \r\n",
        "        ticker,\r\n",
        "        period_end,\r\n",
        "        fiscal_year,\r\n",
        "        period_type,\r\n",
        "        value / 1e9 AS revenue_bn\r\n",
        "    FROM main.financials.financials\r\n",
        "    WHERE concept     = 'Revenue'\r\n",
        "      AND period_type IN ('Q1','Q2','Q3','Q4')\r\n",
        "),\r\n",
        "with_yoy AS (\r\n",
        "    SELECT \r\n",
        "        ticker,\r\n",
        "        period_end,\r\n",
        "        fiscal_year,\r\n",
        "        period_type,\r\n",
        "        revenue_bn,\r\n",
        "        LAG(revenue_bn, 4) OVER (\r\n",
        "            PARTITION BY ticker \r\n",
        "            ORDER BY period_end\r\n",
        "        ) AS revenue_prev_year\r\n",
        "    FROM quarterly\r\n",
        ")\r\n",
        "SELECT \r\n",
        "    ticker,\r\n",
        "    period_end,\r\n",
        "    CONCAT(CAST(fiscal_year AS STRING), '-', period_type) AS quarter_label,\r\n",
        "    ROUND(revenue_bn, 2) AS revenue_bn,\r\n",
        "    CASE \r\n",
        "        WHEN revenue_prev_year > 0 \r\n",
        "        THEN ROUND((revenue_bn - revenue_prev_year) / revenue_prev_year * 100, 1)\r\n",
        "    END AS yoy_pct\r\n",
        "FROM with_yoy\r\n",
        "ORDER BY ticker, period_end"
      ]
    },
    {
