        "    FROM main.financials.financials f\r\n",
        "    JOIN main.config.concept_hierarchy h\r\n",
        "        ON h.stmt = f.stmt AND h.concept = f.concept\r\n",
        "    WHERE f.stmt        = 'Income Statement'\r\n",
        "      AND f.period_type IN ('Q1','Q2','Q3','Q4')\r\n",
        "      AND h.section    <> 'Per Share Data'\r\n",
        ")\r\n",
        "SELECT\r\n",
        "    ticker,\r\n",
        "    CONCAT(CAST(fiscal_year AS STRING), '-', period_type) AS quarter_label,\r\n",
        "    LPAD(CAST(section_sort AS STRING), 3, '0') || ' ' || section AS section,\r\n",
        "    CASE\r\n",
        "        WHEN display_name IN ('Gross Profit', 'Operating Income', 'Operating Expenses',\r\n",
        "                              'Income Before Tax', 'Net Income')\r\n",
        "            THEN LPAD(CAST(sort_order AS STRING), 3, '0') || ' ▸ ' || UPPER(display_name)\r\n",
        "        ELSE LPAD(CAST(sort_order AS STRING), 3, '0') || '   ' || display_name\r\n",
        "    END AS concept,\r\n",
        "    ROUND(SUM(value) / 1e6, 2) AS value_mn\r\n",
        "FROM quarterly\r\n",
        "GROUP BY\r\n",
        "    ticker, fiscal_year, period_type, section_sort, section, sort_order, display_name\r\n",
        "ORDER BY\r\n",
        "    ticker, fiscal_year, period_type, sort_order"
      ]
    },
    {
      "name": "1626af2e",
      "displayName": "ds_quarterly_balance_sheet",
      "queryLines": [
        "WITH bs_quarterly AS (\r\n",
        "    SELECT\r\n",
        "        f.ticker,\r\n",
        "        f.period_end,\r\n",
        "        f.fiscal_year,\r\n",
        "        f.period_type,\r\n",
        "        f.value,\r\n",
        "        h.section,\r\n",
        "        h.`group`,\r\n",
        "        h.display_name,\r\n",
        "        h.sort_order,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY f.stmt, h.section)            AS section_sort,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY f.stmt, h.section, h.`group`) AS group_sort\r\n",
        "    FROM main.financials.financials f\r\n",
        "    JOIN main.config.concept_hierarchy h\r\n",
        "        ON h.stmt = f.stmt AND h.concept = f.concept\r\n",
        "    WHERE f.stmt        = 'Balance Sheet'\r\n",
        "      AND f.period_type IN ('Q1','Q2','Q3','Q4')\r\n",
        "),\r\n",
        "ranked AS (\r\n",
        "    SELECT \r\n",
        "        *,\r\n",
        "        ROW_NUMBER() OVER (\r\n",
        "            PARTITION BY ticker, display_name \r\n",
        "            ORDER BY period_end DESC\r\n",
        "        ) AS rn_latest,\r\n",
        "        LAG(value, 4) OVER (\r\n",
        "            PARTITION BY ticker, display_name \r\n",
        "            ORDER BY period_end\r\n",
        "        ) AS value_prev_year\r\n",
        "    FROM bs_quarterly\r\n",
        ")\r\n",
        "SELECT\r\n",
        "    ticker,\r\n",
        "    CONCAT(CAST(fiscal_year AS STRING), '-', period_type) AS quarter_label,\r\n",
        "    LPAD(CAST(section_sort AS STRING), 3, '0') || ' ' || section AS section,\r\n",
        "    CASE\r\n",
        "        WHEN `group` IS NULL\r\n",
        "            THEN LPAD(CAST(sort_order AS STRING), 3, '0') || ' —'\r\n",
        "        ELSE LPAD(CAST(group_sort AS STRING), 3, '0') || ' ' || `group`\r\n",
        "    END AS `group`,\r\n",
        "    CASE\r\n",
        "        WHEN display_name LIKE 'Total%'\r\n",
        "            THEN LPAD(CAST(sort_order AS STRING), 3, '0') || ' ▸ ' || UPPER(display_name)\r\n",
        "        ELSE LPAD(CAST(sort_order AS STRING), 3, '0') || '   ' || display_name\r\n",
        "    END AS concept,\r\n",
        "    ROUND(value           / 1e6, 2) AS value_mn,\r\n",
        "    ROUND(value_prev_year / 1e6, 2) AS value_prev_year_mn,\r\n",
        "    CASE \r\n",
        "        WHEN value_prev_year > 0 \r\n",
        "        THEN ROUND((value - value_prev_year) / value_prev_year * 100, 1)\r\n",
        "    END AS yoy_pct\r\n",
        "FROM ranked\r\n",
        "WHERE rn_latest <= 8\r\n",
        "ORDER BY ticker, period_end DESC, sort_order"
      ]
    }
