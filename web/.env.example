# Copy to web/.env and adjust. The values below are safe local-dev defaults.
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=postgres://postgres:postgres@db:5432/fundamentals
# Company logos via Logo.dev (publishable key). Empty ⇒ monogram fallback everywhere.
LOGO_DEV_KEY=

# ── Production (config.settings.prod) ────────────────────────────────────────────────
# Set these in the platform's secret store — NEVER commit real values. prod.py has no
# insecure fallbacks: a missing secret/hosts/database fails the boot.
#   DJANGO_SETTINGS_MODULE=config.settings.prod
#   DJANGO_SECRET_KEY=<50+ random chars, e.g. `python -c "import secrets;print(secrets.token_urlsafe(64))"`>
#   DJANGO_ALLOWED_HOSTS=fundamentals-web.onrender.com
#   DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
#                                   # Aiven for PostgreSQL: copy verbatim from the service's "Quick
#                                   #   connect" page — it already includes ?sslmode=require, which
#                                   #   django-environ passes through to the DB backend untouched
#                                   #   (no code change needed for SSL).
#   DJANGO_CONN_MAX_AGE=60           # optional; DB connection reuse (seconds) — acts as lightweight
#                                   #   pooling; plenty for a single free-tier instance against
#                                   #   Aiven's free-plan connection cap, no PgBouncer needed
#   DJANGO_CSRF_TRUSTED_ORIGINS=https://fundamentals-web.onrender.com
#                                   # REQUIRED behind an https proxy or login/signup POST 403s
#   DJANGO_NUM_PROXIES=1            # optional; proxy hop count so the API throttle keys on the
#                                   #   real client IP (Render adds one hop; default 1 in prod)
#   API_THROTTLE_ANON=120/min      # optional; per-IP rate limit for the public REST API
#   RUN_MIGRATIONS_ON_BOOT=true    # Render free plan only — no pre-deploy command on that plan,
#                                   #   see web/docker/entrypoint.prod.sh and docs/deploy-render.md
# Serve with gunicorn (after `python manage.py collectstatic --noinput && migrate`):
#   python manage.py warm_artifact_cache        # pre-warm the artifact cache (no cold start)
#   gunicorn config.wsgi:application --bind 0.0.0.0:8000
# Re-run `warm_artifact_cache` on the Release publish cadence (cron / systemd timer) to keep the
# cache aligned with each publish. Reads self-heal too (stale-while-revalidate). Optional tuning:
#   ARTIFACTS_TTL=600                # seconds before a cached artifact is considered stale
#   ARTIFACTS_REFRESH_ASYNC=true     # background (non-blocking) revalidation of stale artifacts
# Point the platform health check / uptime monitor at:
#   GET /healthz   liveness  (200 = process up; do not restart)
#   GET /readyz    readiness (200 = DB + cached artifacts healthy; 503 = drain this instance)
# Error tracking (Sentry) — inert unless SENTRY_DSN is set; APP_RELEASE tags events by deploy:
#   SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
#   SENTRY_ENVIRONMENT=production    # optional; defaults to "production"
#   APP_RELEASE=<git-sha>            # optional; ties error spikes to the deploy that shipped them
#   SENTRY_TRACES_SAMPLE_RATE=0.0    # optional; performance tracing sample rate (0 = off)
