{
  "datasets": [
    {
      "name": "3faf0071",
      "displayName": "ds_income_statement",
      "queryLines": [
        "SELECT ticker, year, concept,\r\n",
        "    ROUND(SUM(value) / 1e6, 2) AS value_mn\r\n",
        "FROM main.financials.financials\r\n",
        "WHERE stmt = 'Income Statement'\r\n",
        "GROUP BY ticker, year, concept\r\n",
        "ORDER BY year"
      ]
    },
    {
      "name": "e0d529a9",
      "displayName": "ds_cash_flow",
      "queryLines": [
        "SELECT ticker, year, concept,\r\n",
        "    ROUND(SUM(value) / 1e6, 2) AS value_mn\r\n",
        "FROM main.financials.financials\r\n",
        "WHERE stmt = 'Cash Flow'\r\n",
        "GROUP BY ticker, year, concept\r\n",
        "ORDER BY year"
      ]
    },
    {
      "name": "6646c7a4",
      "displayName": "ds_balance_sheet",
      "queryLines": [
        "SELECT ticker, year, concept,\r\n",
        "    ROUND(SUM(value) / 1e6, 2) AS value_mn\r\n",
        "FROM main.financials.financials\r\n",
        "WHERE stmt = 'Balance Sheet'\r\n",
        "GROUP BY ticker, year, concept\r\n",
        "ORDER BY year"
      ]
    },
    {
      "name": "96deb0c6",
      "displayName": "devired_metrics",
      "queryLines": [
        "SELECT ticker, year, metric, round(any_value(value), 2) as value\r\n",
        "FROM main.financials.financials_metrics\r\n",
        "GROUP BY ticker, year, metric\r\n",
        "ORDER BY year"
      ]
    }
  ],
