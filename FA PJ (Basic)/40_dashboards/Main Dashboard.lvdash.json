{
  "datasets": [
    {
      "name": "6646c7a4",
      "displayName": "ds_balance_sheet",
      "queryLines": [
        "WITH ranked AS (\r\n",
        "    SELECT\r\n",
        "        f.ticker,\r\n",
        "        f.year,\r\n",
        "        f.value,\r\n",
        "        h.section,\r\n",
        "        h.`group`,\r\n",
        "        h.display_name,\r\n",
        "        h.sort_order,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY f.stmt, h.section)            AS section_sort,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY f.stmt, h.section, h.`group`) AS group_sort\r\n",
        "    FROM main.financials.financials f\r\n",
        "    JOIN main.config.concept_hierarchy h\r\n",
        "        ON h.stmt = f.stmt AND h.concept = f.concept\r\n",
        "    WHERE f.stmt = 'Balance Sheet'\r\n",
        ")\r\n",
        "SELECT\r\n",
        "    ticker,\r\n",
        "    year,\r\n",
        "    LPAD(CAST(section_sort AS STRING), 3, '0') || ' ' || section AS section,\r\n",
        "    CASE\r\n",
        "        WHEN `group` IS NULL\r\n",
        "            THEN LPAD(CAST(sort_order AS STRING), 3, '0') || ' —'\r\n",
        "        ELSE LPAD(CAST(group_sort AS STRING), 3, '0') || ' ' || `group`\r\n",
        "    END AS `group`,\r\n",
        "    CASE\r\n",
        "        WHEN display_name LIKE 'Total%'\r\n",
        "            THEN LPAD(CAST(sort_order AS STRING), 3, '0') || ' ▸ ' || UPPER(display_name)\r\n",
        "        ELSE LPAD(CAST(sort_order AS STRING), 3, '0') || '   ' || display_name\r\n",
        "    END AS concept,\r\n",
        "    ROUND(SUM(value) / 1e6, 2) AS value_mn\r\n",
        "FROM ranked\r\n",
        "GROUP BY\r\n",
        "    ticker, year, section_sort, section, `group`, sort_order, display_name, group_sort\r\n",
        "ORDER BY\r\n",
        "    ticker, year, sort_order"
      ]
    },
    {
      "name": "3faf0071",
      "displayName": "ds_income_statement",
      "queryLines": [
        "WITH ranked AS (\r\n",
        "    SELECT\r\n",
        "        f.ticker,\r\n",
        "        f.year,\r\n",
        "        f.value,\r\n",
        "        h.section,\r\n",
        "        h.display_name,\r\n",
        "        h.sort_order,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY f.stmt, h.section) AS section_sort\r\n",
        "    FROM main.financials.financials f\r\n",
        "    JOIN main.config.concept_hierarchy h\r\n",
        "        ON h.stmt = f.stmt AND h.concept = f.concept\r\n",
        "    WHERE f.stmt = 'Income Statement'\r\n",
        "      AND h.section <> 'Per Share Data'   -- esta sección va a un widget aparte\r\n",
        ")\r\n",
        "SELECT\r\n",
        "    ticker,\r\n",
        "    year,\r\n",
        "    LPAD(CAST(section_sort AS STRING), 3, '0') || ' ' || section AS section,\r\n",
        "    CASE\r\n",
        "        WHEN display_name IN ('Gross Profit', 'Operating Income', 'Operating Expenses',\r\n",
        "                              'Income Before Tax', 'Net Income')\r\n",
        "            THEN LPAD(CAST(sort_order AS STRING), 3, '0') || ' ▸ ' || UPPER(display_name)\r\n",
        "        ELSE LPAD(CAST(sort_order AS STRING), 3, '0') || '   ' || display_name\r\n",
        "    END AS concept,\r\n",
        "    ROUND(SUM(value) / 1e6, 2) AS value_mn\r\n",
        "FROM ranked\r\n",
        "GROUP BY\r\n",
        "    ticker, year, section_sort, section, sort_order, display_name\r\n",
        "ORDER BY\r\n",
        "    ticker, year, sort_order"
      ]
    },
    {
      "name": "e0d529a9",
      "displayName": "ds_cash_flow",
      "queryLines": [
        "WITH ranked AS (\r\n",
        "    SELECT\r\n",
        "        f.ticker,\r\n",
        "        f.year,\r\n",
        "        f.value,\r\n",
        "        h.section,\r\n",
        "        h.display_name,\r\n",
        "        h.sort_order,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY f.stmt, h.section) AS section_sort\r\n",
        "    FROM main.financials.financials f\r\n",
        "    JOIN main.config.concept_hierarchy h\r\n",
        "        ON h.stmt = f.stmt AND h.concept = f.concept\r\n",
        "    WHERE f.stmt = 'Cash Flow'\r\n",
        ")\r\n",
        "SELECT\r\n",
        "    ticker,\r\n",
        "    year,\r\n",
        "    LPAD(CAST(section_sort AS STRING), 3, '0') || ' ' || section AS section,\r\n",
        "    CASE\r\n",
        "        WHEN display_name IN ('Operating CF', 'Investing CF', 'Financing CF', 'Net Change in Cash')\r\n",
        "            THEN LPAD(CAST(sort_order AS STRING), 3, '0') || ' ▸ ' || UPPER(display_name)\r\n",
        "        ELSE LPAD(CAST(sort_order AS STRING), 3, '0') || '   ' || display_name\r\n",
        "    END AS concept,\r\n",
        "    ROUND(SUM(value) / 1e6, 2) AS value_mn\r\n",
        "FROM ranked\r\n",
        "GROUP BY\r\n",
        "    ticker, year, section_sort, section, sort_order, display_name\r\n",
        "ORDER BY\r\n",
        "    ticker, year, sort_order"
      ]
    },
    {
      "name": "96deb0c6",
      "displayName": "devired_metrics",
      "queryLines": [
        "WITH ranked AS (\r\n",
        "    SELECT\r\n",
        "        m.ticker,\r\n",
        "        m.year,\r\n",
        "        m.value,\r\n",
        "        h.category,\r\n",
        "        h.subcategory,\r\n",
        "        h.metric,\r\n",
        "        h.sort_order,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY h.category)              AS category_sort,\r\n",
        "        MIN(h.sort_order) OVER (PARTITION BY h.category, h.subcategory) AS subcategory_sort\r\n",
        "    FROM main.financials.financials_metrics m\r\n",
        "    JOIN main.config.metrics_hierarchy h\r\n",
        "        ON h.metric = m.metric\r\n",
        ")\r\n",
        "SELECT\r\n",
        "    ticker,\r\n",
        "    year,\r\n",
        "    LPAD(CAST(category_sort    AS STRING), 3, '0') || ' ' || category    AS category,\r\n",
        "    LPAD(CAST(subcategory_sort AS STRING), 3, '0') || ' ' || subcategory AS subcategory,\r\n",
        "    LPAD(CAST(sort_order       AS STRING), 3, '0') || ' ' || metric      AS metric,\r\n",
        "    ROUND(ANY_VALUE(value), 2) AS value\r\n",
        "FROM ranked\r\n",
        "GROUP BY\r\n",
        "    ticker, year, category_sort, category, subcategory_sort, subcategory, sort_order, metric\r\n",
        "ORDER BY\r\n",
        "    ticker, year, sort_order"
      ]
    }
  ],
